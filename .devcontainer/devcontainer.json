{
  "name": "sandbox-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers-extra/features/mise": {}
  },
  "init": true,
  "runArgs": ["--env-file", ".devcontainer/devcontainer.env", "--rm"],
  "forwardPorts": [3000, 4983],
  "mounts": [
    "source=${localWorkspaceFolder}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localWorkspaceFolder}/.codex,target=/home/vscode/.codex,type=bind"
  ],
  "remoteEnv": {
    "PATH": "/home/vscode/.local/share/mise/shims:/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "MS-CEINTL.vscode-language-pack-ja",
        "vitest.explorer",
        "vscode-icons-team.vscode-icons",
        "Vue.volar"
      ]
    }
  },
  "initializeCommand": "bash .devcontainer/script/initialize_command.sh",
  "onCreateCommand": "bash .devcontainer/script/on_create_command.sh",
  "postStartCommand": "bash .devcontainer/script/post_start_command.sh",
  "postAttachCommand": "bash .devcontainer/script/post_attach_command.sh",
  "waitFor": "postStartCommand"
}
