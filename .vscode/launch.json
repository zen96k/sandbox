{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Sandbox Server",
      "preLaunchTask": "npm-install-sandbox",
      "runtimeExecutable": "${env:HOME}/.local/share/mise/shims/npm",
      "cwd": "${workspaceFolder}/sandbox",
      "runtimeArgs": ["run", "dev"],
      "outputCapture": "std"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Sandbox Client",
      "preLaunchTask": "wait-for-sandbox-server",
      "runtimeArgs": [
        "--incognito",
        "--auto-open-devtools-for-tabs",
        "http://localhost:3000"
      ],
      "webRoot": "${workspaceFolder}/sandbox"
    }
  ],
  "compounds": [
    {
      "name": "Debug Mode",
      "configurations": ["Sandbox Server", "Sandbox Client"]
    }
  ]
}
